# ==== VISUAL ====

def barra_vida(atual, maximo):
    tamanho = 20
    proporcao = atual / maximo
    cheio = int(proporcao * tamanho)
    return "█" * cheio + "-" * (tamanho - cheio)

def limpar():
    print("\n" * 3)

