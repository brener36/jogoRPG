def escolher_grimorio():

    print("\n📖 ESCOLHA SEU GRIMÓRIO 📖\n")

    lista_grimorios = list(grimorios.keys())

    for i, grimorio in enumerate(lista_grimorios):
        raridade = grimorios[grimorio]["raridade"]
        print(f"{i+1}. {grimorio} ({raridade})")

    escolha = int(input("\nDigite o número do grimório: ")) - 1

    grimorio_escolhido = lista_grimorios[escolha]

    jogador["grimorio"] = grimorio_escolhido
    jogador["magias"] = grimorios[grimorio_escolhido]["magias"]

    print(f"\n✨ Você recebeu o grimório de {grimorio_escolhido}!")

# ==== ITENS ====

def usar_item_combate(inimigo):

    if not jogador["inventario"]:
        print("\n🎒 Seu inventário está vazio!")
        time.sleep(1)
        return False

    print("\n🧪 Itens disponíveis:")

    for i, item in enumerate(jogador["inventario"]):
        print(f"{i+1} - {item}")

    print("0 - Voltar")

    escolha = input("Escolha um item: ")

    if escolha == "0":
        return False

    try:
        indice = int(escolha) - 1
        item = jogador["inventario"][indice]

    except (ValueError, IndexError):
        print("\nOpção inválida!")
        time.sleep(1)
        return False

    jogador["inventario"].pop(indice)

    nome_item = item.lower()

    if "vida" in nome_item or "cura" in nome_item:

        cura = 50
        jogador["vida"] = min(jogador["vida"] + cura, jogador["vida_max"])

        print(f"\n❤️ Você usou {item} e recuperou {cura} de vida!")

    elif "mana" in nome_item:

        recupera = 50
        jogador["mana"] = min(jogador["mana"] + recupera, jogador["mana_max"])

        print(f"\n🔮 Você usou {item} e recuperou {recupera} de mana!")

    else:

        dano = 30
        inimigo["vida"] -= dano

        print(f"\n💣 Você usou {item} e causou {dano} de dano no inimigo!")

    time.sleep(1)
    return True

# ==== MAGIAS ====

def usar_magia(inimigo):

    if not jogador["magias"]:
        print("\n📕 Você ainda não tem um grimório com magias disponíveis!")
        time.sleep(1)
        return False

    print("\n✨ Magias disponíveis:")

    for i, magia in enumerate(jogador["magias"]):
        print(f"{i+1} - {magia['nome']} (Dano: {magia['dano']}, Mana: {magia['mana']})")

    print("0 - Voltar")

    escolha = input("Escolha uma magia: ")

    if escolha == "0":
        return False

    try:
        indice = int(escolha) - 1
        magia = jogador["magias"][indice]
    except (ValueError, IndexError):
        print("\nOpção inválida!")
        time.sleep(1)
        return False

    if jogador["mana"] < magia["mana"]:
        print("\n🔋 Mana insuficiente para usar essa magia!")
        time.sleep(1)
        return False

    jogador["mana"] -= magia["mana"]
    inimigo["vida"] -= magia["dano"]

    print(f"\n✨ Você conjurou {magia['nome']} e causou {magia['dano']} de dano!")
    print(f"🔮 Mana restante: {jogador['mana']}/{jogador['mana_max']}")

    time.sleep(1)
    return True

# ==== BATALHA ====

def batalha():

    inimigo = random.choice(inimigos).copy()

    vida_max_inimigo = inimigo["vida"]

    print(f"\n⚔️ Um {inimigo['nome']} apareceu!")

    time.sleep(1)

    while inimigo["vida"] > 0 and jogador["vida"] > 0:

        limpar()

        print("=" * 30)
        print(f"🧙 {jogador['nome']}")
        print(f"[{barra_vida(jogador['vida'], jogador['vida_max'])}] {jogador['vida']}")

        print(f"\n👹 {inimigo['nome']}")
        print(f"[{barra_vida(inimigo['vida'], vida_max_inimigo)}] {inimigo['vida']}")
        print("=" * 30)

        print("\n1 - Atacar")
        print("2 - Usar magia")
        print("3 - Usar item")
        print("4 - Fugir")

        escolha = input("Escolha: ")

        # TURNO DO JOGADOR

        if escolha == "1":

            print("\n⚔️ Você atacou!")

            inimigo["vida"] -= jogador["ataque"]

            print(f"💥 Dano causado: {jogador['ataque']}")

            time.sleep(1)

        elif escolha == "2":

            usou = usar_magia(inimigo)

            if not usou:
                continue

        elif escolha == "3":

            usou = usar_item_combate(inimigo)

            if not usou:
                continue

        elif escolha == "4":

            print("\n🏃 Você fugiu!")

            time.sleep(1)

            return

        else:

            print("\n❌ Opção inválida!")
            time.sleep(1)
            continue

        # INIMIGO MORREU

        if inimigo["vida"] <= 0:
            break

        # TURNO DO INIMIGO

        print("\n👹 O inimigo atacou!")

        jogador["vida"] -= inimigo["ataque"]

        print(f"⚠️ Você recebeu {inimigo['ataque']} de dano!")

        time.sleep(1)

    # RESULTADO

    if jogador["vida"] > 0:

        print(f"\n🏆 Você derrotou {inimigo['nome']}!")

    else:

        print("\n💀 Você foi derrotado!")

        exit()

    time.sleep(2)

